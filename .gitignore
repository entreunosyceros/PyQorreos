# --- Entorno virtual ---
.venv/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
*.manifest
*.spec



# --- Configuración y datos sensibles del usuario ---
# (también se guardan en ~/.config/pyqorreos/)
.env
.env.*
*.env
secrets.json
credentials.json
accounts.json
classification.json
preferences.json
oauth_clients.json
mail_cache.db
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Exportaciones de correo (no subir mensajes reales al repositorio)
*.eml
*.mbox

# --- Herramientas de test y cobertura ---
tests/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
unittest.xml

# --- Empaquetado Debian (.deb) ---
# Fuentes de empaquetado (no subir; conservar en local o en releases)
/debian/
/scripts/
requirements-runtime.txt
# Artefactos generados por dpkg-buildpackage
*.deb
*.changes
*.buildinfo
*.dsc
*.tar.xz
*.upload

# --- Otros instaladores ---
*.dmg
*.app
*.exe
*.msi
