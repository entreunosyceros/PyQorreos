#!/usr/bin/make -f
# Empaquetado Debian: código en /usr/share/pyqorreos; .venv lo crea run_app.py.

export DH_VERBOSE = 1
export PYQORREOS_SHARE = $(CURDIR)/debian/pyqorreos/usr/share/pyqorreos

%:
	dh $@

override_dh_auto_clean:
	rm -rf $(PYQORREOS_SHARE)

override_dh_auto_build:
	# Sin compilación nativa del proyecto.

override_dh_auto_install:
	install -d $(PYQORREOS_SHARE)
	cp -r pyqorreos $(PYQORREOS_SHARE)/
	cp run_app.py requirements.txt $(PYQORREOS_SHARE)/
	find $(PYQORREOS_SHARE) -name '.gitignore' -delete
	find $(PYQORREOS_SHARE) -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	install -d $(CURDIR)/debian/pyqorreos/usr/bin
	install -m 755 debian/pyqorreos-launcher $(CURDIR)/debian/pyqorreos/usr/bin/pyqorreos
	install -d $(CURDIR)/debian/pyqorreos/usr/share/applications
	install -m 644 debian/pyqorreos.desktop \
		$(CURDIR)/debian/pyqorreos/usr/share/applications/
	install -d $(CURDIR)/debian/pyqorreos/usr/share/icons/hicolor/scalable/apps
	install -m 644 pyqorreos/img/ui/mail.svg \
		$(CURDIR)/debian/pyqorreos/usr/share/icons/hicolor/scalable/apps/pyqorreos.svg
	install -d $(CURDIR)/debian/pyqorreos/usr/share/doc/pyqorreos
	install -m 644 README.md $(CURDIR)/debian/pyqorreos/usr/share/doc/pyqorreos/README.md
